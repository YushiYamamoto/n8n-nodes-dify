{
  "name": "n8n-nodes-dify",
  "version": "0.0.1",
  "description": "n8n community node for Dify API integration",
  "license": "MIT",
  "homepage": "https://github.com/YushiYamamoto/n8n-nodes-dify",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "dify",
    "ai",
    "automation"
  ],
  "author": {
    "name": "Yushi Yamamoto",
    "email": "32246139+YushiYamamoto@users.noreply.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/YushiYamamoto/n8n-nodes-dify.git"
  },
  "bugs": {
    "url": "https://github.com/YushiYamamoto/n8n-nodes-dify/issues"
  },
  "scripts": {
    "build": "n8n-node build",
    "build:watch": "tsc --watch",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lint:fix": "n8n-node lint --fix",
    "release": "n8n-node release",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/DifyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Dify/Dify.node.js"
    ]
  },
  "devDependencies": {
    "@n8n/node-cli": "*",
    "eslint": "9.39.4",
    "prettier": "3.8.1",
    "release-it": "19.2.4",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}